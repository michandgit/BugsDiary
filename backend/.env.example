# MongoDB Configuration
# Replace with your actual MongoDB Atlas credentials
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/BugsDiary?appName=Cluster0
DATABASE_NAME=BugsDiary

# Application Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration (REQUIRED for authentication)
# Generate a cryptographically secure secret key (>32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-cryptographically-secure-jwt-secret-key-here
JWT_EXPIRATION=7d

# Security Notes:
# 1. Never commit the actual .env file to version control
# 2. Rotate JWT_SECRET in production deployments
# 3. Use strong, unique MongoDB credentials
# 4. Consider using environment-specific secrets management